{
  "version": 2,
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/article",
      "destination": "/produits",
      "permanent": true
    },
    {
      "source": "/article/",
      "destination": "/produits/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}

