{
  "version": 2,
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/article",
      "destination": "/produits",
      "permanent": true
    },
    {
      "source": "/article/",
      "destination": "/produits/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/admin/packs/:slug", "destination": "/api/admin/packs.js" },
    { "source": "/api/admin/products/:slug", "destination": "/api/admin/products.js" },
    { "source": "/api/admin/orders/:id", "destination": "/api/admin/orders.js" }
  ]
}


