# Clés Supabase (Backend & Frontend)
# Allez sur https://supabase.com/dashboard → Project Settings → API

# ─── Frontend (injectées dans le HTML par le serveur) ───────────────────────
# URL publique de votre projet Supabase
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co

# Clé anonyme (sûre à exposer côté client)
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ─── Backend uniquement (NE JAMAIS exposer côté client) ─────────────────────
# Clé Service Role — accès illimité à la base de données (admin uniquement)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Email de l'administrateur du panneau d'administration
ADMIN_EMAIL=admin@lecanape-dz.com

# ─── CORS ───────────────────────────────────────────────────────────────────
# Origines autorisées pour les requêtes cross-origin (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,https://lecanape-dz.com,https://www.lecanape-dz.com

# ─── Stockage d'images ───────────────────────────────────────────────────────
# Option 1 : Vercel Blob (recommandé sur Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Option 2 : cPanel upload personnalisé
# URL de l'API PHP d'upload sur votre serveur cPanel
CPANEL_UPLOAD_URL=https://lecanape-dz.com/api/upload.php

# Secret partagé entre l'API Vercel et le script PHP cPanel
UPLOAD_SECRET=votre_secret_aleatoire_ici

# ─── Cache / Base de données KV (optionnel) ──────────────────────────────────
# URL de l'API REST Vercel KV (si vous utilisez Vercel KV pour le cache produits)
KV_REST_API_URL=https://your-kv.kv.vercel-storage.com
KV_REST_API_TOKEN=votre_token_kv_ici

# ─── Environnement ───────────────────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Une fois rempli, renommez ce fichier de ".env.example" à ".env"
# Ne committez JAMAIS le fichier .env dans Git !
# Vérifiez que .env est dans votre .gitignore
