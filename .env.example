# Admin password (required in production)
ADMIN_PASSWORD=your-secure-password-here

# Optional: secret for session signing (defaults to ADMIN_PASSWORD)
# ADMIN_SECRET=random-long-string

# Optional Vercel Blob - only needed later if deploying uploads to Vercel
# BLOB_READ_WRITE_TOKEN=

# Optional remote storage for product edits later
# Create a Redis/KV store in Vercel dashboard -> Storage -> Connect to project
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
