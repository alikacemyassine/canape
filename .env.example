# ─── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API

# Public URL of your Supabase project
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co

# Anon key (safe to expose client-side)
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Service Role key — full DB access (server-side only, never expose)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── Admin ───────────────────────────────────────────────────────────────────
# The email of the admin account (must match a user in Supabase Auth)
ADMIN_EMAIL=your-admin@email.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for API calls
ALLOWED_ORIGINS=http://localhost:3000

# ─── SMTP (optional, for email features) ─────────────────────────────────────
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Rename this file to ".env" and fill in your values.
# NEVER commit the .env file to Git!
